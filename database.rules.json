{
  "rules_version": "2",
  "firestore": {
    "rules_version": "2",
    "service cloud.firestore": {
      "match /databases/{database}/documents": {
        "function signedIn()": "return request.auth != null",
        "function isOwner(userId)": "return signedIn() && request.auth.uid == userId",
        "function areFriends(userId)": "return signedIn() && exists(/databases/$(database)/documents/friendships/$(userId < request.auth.uid ? userId + '_' + request.auth.uid : request.auth.uid + '_' + userId)) && get(/databases/$(database)/documents/friendships/$(userId < request.auth.uid ? userId + '_' + request.auth.uid : request.auth.uid + '_' + userId)).data.status == 'accepted'",
        "match /users/{userId}": { "allow read": "if signedIn()", "allow write": "if isOwner(userId)" },
        "match /friendships/{friendshipId}": { "allow read": "if signedIn()", "allow create, update, delete": "if signedIn()" },
        "match /groups/{groupId}": { "allow read": "if signedIn()", "allow create, update": "if signedIn()", "match /messages/{messageId}": { "allow read, create": "if signedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members" } },
        "match /locations_history/{historyId}": { "allow read": "if signedIn()", "allow create": "if isOwner(request.resource.data.uid)", "allow update, delete": "if isOwner(resource.data.uid)" },
        "match /moments/{momentId}": { "allow read": "if signedIn()", "allow create": "if isOwner(request.resource.data.userId)", "allow update, delete": "if isOwner(resource.data.userId)" },
        "match /groups_visibility/{visibilityId}": { "allow read, write": "if signedIn()" },
        "match /direct_chats/{chatId}": { "allow read, write": "if signedIn()", "match /messages/{msgId}": { "allow read, create": "if signedIn()" } },
        "match /locations/{uid}": { "allow read": "if signedIn()", "allow write": "if isOwner(uid)" },
        "match /location_visibility/{uid}": { "allow read": "if isOwner(uid)", "match /{otherUid}": { "allow write": "if isOwner(uid)" } },
        "match /interactions/{uid}": { "allow read": "if isOwner(uid)", "allow create": "if signedIn()", "allow update, delete": "if isOwner(uid)" },
        "match /gifts/{giftId}": { "allow read": "if signedIn()", "allow write": "if signedIn()" }
      }
    }
  }
}
