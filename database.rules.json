{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "locations": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "location_visibility": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$visibleUid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "interactions": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    }
  }
}
