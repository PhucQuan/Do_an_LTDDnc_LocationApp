rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function friendshipDocId(userId1, userId2) {
      return userId1 < userId2 ? userId1 + "_" + userId2 : userId2 + "_" + userId1;
    }

    function areFriends(userId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/friendships/$(friendshipDocId(request.auth.uid, userId))) &&
        get(/databases/$(database)/documents/friendships/$(friendshipDocId(request.auth.uid, userId))).data.status == 'accepted';
    }

    function sameGroup(userId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/groups_visibility/$(request.auth.uid + "_" + userId));
    }

    function canSeeUser(userId) {
      return isOwner(userId) || areFriends(userId) || sameGroup(userId);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isOwner(userId);
    }

    match /friendships/{friendshipId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create, update: if signedIn();

      match /messages/{messageId} {
        allow read, create: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }

    match /locations_history/{historyId} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.uid);
      allow update, delete: if isOwner(resource.data.uid);
    }

    match /moments/{momentId} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /register_otps/{email} {
      allow read, write: if true;
    }

    match /password_resets/{email} {
      allow read, write: if true;
    }

    match /groups_visibility/{visibilityId} {
      allow read, write: if signedIn();
    }

    // ── Direct chats ────────────────────────────────────────────────
    match /direct_chats/{chatId} {
      allow read, write: if signedIn();
      match /messages/{msgId} {
        allow read, create: if signedIn();
      }
    }

    // ── Locations ────────────────────────────────────────────────────
    match /locations/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid);
    }

    // ── Location visibility ──────────────────────────────────────────
    match /location_visibility/{uid} {
      allow read: if isOwner(uid);
      match /{otherUid} {
        allow write: if isOwner(uid);
      }
    }

    // ── Interactions ────────────────────────────────────────────────
    match /interactions/{uid} {
      allow read: if isOwner(uid);
      allow create: if signedIn();
      allow update, delete: if isOwner(uid);
    }

    // ── Gifts ───────────────────────────────────────────────────────
    match /gifts/{giftId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }
  }
}
